  "outputs": {
    "backend_config": {
      "value": "\n============================================================\nTerraform Backend Configuration\n============================================================\n\nAlready committed in terraform/backend.tfvars.\nOnly the storage_account_name is injected at init time.\n\nresource_group_name  = \"rg-ccworkshop-shared\"\nstorage_account_name = \"ftccccworkshoptfstate\"\ncontainer_name       = \"tfstate\"\nkey                  = \"ai-democase.tfstate\"\nuse_oidc             = true\n\n============================================================\n",
      "type": "string"
    },
    "github_actions_configuration": {
      "value": "\n============================================================\nGitHub Configuration Instructions\n============================================================\n\nNo GitHub Environments needed (single environment, repo-level config).\n\n1. REPOSITORY SECRETS (Settings -\u003e Secrets -\u003e Actions):\n   AZURE_TENANT_ID:       77347a0d-fdb5-4c51-9172-aaacde3216d4\n   AZURE_SUBSCRIPTION_ID: 3d1af742-2662-43e2-b67b-a09b782a8e1f\n   AZURE_CLIENT_ID:       c5d53015-1ff1-4133-bb3c-a5e974976a34\n\n2. REPOSITORY VARIABLES (Settings -\u003e Variables -\u003e Actions):\n   STORAGE_ACCOUNT_NAME:  ftccccworkshoptfstate\n   UNIQUE_SUFFIX:         \u003cyour unique prefix, e.g. \"ft\"\u003e\n\n============================================================\n",
      "type": "string"
    },
    "managed_identity_client_id": {
      "value": "c5d53015-1ff1-4133-bb3c-a5e974976a34",
      "type": "string"
